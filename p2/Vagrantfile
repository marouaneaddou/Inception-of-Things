
Vagrant.configure("2") do |config|

  config.vm.box = "ubuntu/bionic64"
  config.vm.synced_folder "./", "/home/vagrant/deploy"

  config.vm.define "maddouS" do |maddouS|
    maddouS.vm.hostname = "maddouS"
    maddouS.vm.network "private_network", ip: "192.168.56.110"
    config.vm.provider "virtualbox" do |vb|
      vb.memory = "1024"
      vb.cpus = 1
      vm.name = "maddouS"
    end
    config.vm.provision "shell", path: "scripts/install_k3s.sh"
    config.vm.provision "shell", path: "scripts/deploy.sh"
  end

end
